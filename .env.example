# Meridian Chat SDK v2.3.7
# Copy this file to .env for local development.
# Never commit the real .env file.

MONGODB_URI=mongodb://127.0.0.1:27017/meridian_chat

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_GENERATED_BCRYPT_HASH
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
SESSION_MAX_AGE_HOURS=12

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

AI_DEFAULT_MODE=auto
AI_MAX_HISTORY_MESSAGES=20
AI_MAX_OUTPUT_TOKENS=900
AI_REASONING_EFFORT=low
AI_REQUEST_TIMEOUT_MS=60000

# OpenAI hosted Web Search
AI_WEB_SEARCH_ENABLED=true
AI_WEB_SEARCH_CONTEXT_SIZE=medium
AI_WEB_SEARCH_MAX_SOURCES=3

# Strict visible reply limit. Sources, timestamps, and WhatsApp cards/buttons are excluded.
AI_REPLY_CHARACTER_LIMIT=200

# Maximum user-facing AI text replies per customer session.
AI_MAX_REPLIES_PER_SESSION=5

# Conversion policy
CONVERSION_FORCE_DECISION_TURN=3
CONVERSION_MAX_CTA_PER_SESSION=2
CONVERSION_CTA_COOLDOWN_TURNS=2
CONVERSION_SUGGESTION_TTL_MS=900000

# WhatsApp conversion
AI_WHATSAPP_ENABLED=true
AI_WHATSAPP_NUMBER=19342032173
AI_WHATSAPP_CLICK_ENDPOINT=/api/conversion/whatsapp-click

NODE_ENV=development
PORT=3000


# Data retention and cleanup
DATA_RETENTION_ENABLED=true
MESSAGE_RETENTION_DAYS=90
CLOSED_SESSION_RETENTION_DAYS=30
CONVERSION_EVENT_RETENTION_DAYS=180
UPLOAD_RETENTION_DAYS=30
DATA_RETENTION_RUN_INTERVAL_HOURS=24
DATA_RETENTION_BATCH_SIZE=500
